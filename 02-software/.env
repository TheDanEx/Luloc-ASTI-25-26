###############################################################################
# InfluxDB
###############################################################################
INFLUXDB_HTTP_PORT=8086
INFLUXDB_HOST=influx-db
INFLUXDB_TOKEN=supersecrettoken
INFLUXDB_BUCKET=local_system
INFLUXDB_ORG=local_org
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=adminadmin


###############################################################################
# Grafana
###############################################################################
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin


###############################################################################
# Telegraf
###############################################################################
TELEGRAF_COLLECTION_INTERVAL=5s
