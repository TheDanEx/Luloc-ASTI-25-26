void vTaskReadAdc(void *pvParameters)
{
    while (1)
    {
        // Bucle para leer los 8 canales y reducir líneas de código
        for (int i = 0; i < 8; i++)
        {
            // Nota: adc1_get_raw toma el canal como argumento.
            // ADC1_CHANNEL_0 es 0, ADC1_CHANNEL_1 es 1, etc.
            adc_val[i] = adc1_get_raw((adc1_channel_t)i);
            ESP_LOGI(tag, "ADC%d Value: %d", i + 1, adc_val[i]);
        }
        ESP_LOGI(tag, "");
        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}

esp_err_t set_adc(void)
{
    // Configuración del ancho de bits (solo se necesita hacer UNA vez para el ADC1)
    adc1_config_width(ADC_WIDTH_BIT_12);

    // Configuración de atenuación por canal
    adc1_config_channel_atten(ADC1_CHANNEL_0, ADC_ATTEN_DB_11);
    adc1_config_channel_atten(ADC1_CHANNEL_1, ADC_ATTEN_DB_11);
    adc1_config_channel_atten(ADC1_CHANNEL_2, ADC_ATTEN_DB_11);
    adc1_config_channel_atten(ADC1_CHANNEL_3, ADC_ATTEN_DB_11);
    adc1_config_channel_atten(ADC1_CHANNEL_4, ADC_ATTEN_DB_11);
    adc1_config_channel_atten(ADC1_CHANNEL_5, ADC_ATTEN_DB_11);
    adc1_config_channel_atten(ADC1_CHANNEL_6, ADC_ATTEN_DB_11);
    adc1_config_channel_atten(ADC1_CHANNEL_7, ADC_ATTEN_DB_11);
    gpio_set_level(readEnable, 1);
    return ESP_OK;
}
