menu "Robot Configuration"

config ROBOT_CONTROL_PERIOD_MS
    int "Control loop period (ms)"
    default 10

config ROBOT_USE_ETHERNET
    bool "Enable Ethernet"
    default y

    if ROBOT_USE_ETHERNET
        choice ROBOT_ETH_IP_MODE
            prompt "Ethernet IP Configuration"
            default ROBOT_ETH_DHCP
            help
                Select whether to use DHCP or static IP address

            config ROBOT_ETH_DHCP
                bool "DHCP (automatic IP)"
                help
                    Use DHCP to automatically obtain IP address

            config ROBOT_ETH_STATIC_IP
                bool "Static IP address"
                help
                    Use fixed static IP address
        endchoice

        if ROBOT_ETH_STATIC_IP
            config ROBOT_ETH_STATIC_IP_ADDR
                string "Static IP address"
                default "192.168.42.151"
                help
                    Static IP address (e.g., 192.168.42.151)

            config ROBOT_ETH_STATIC_NETMASK
                string "Netmask"
                default "255.255.255.0"
                help
                    Netmask (e.g., 255.255.255.0)

            config ROBOT_ETH_STATIC_GATEWAY
                string "Gateway"
                default "192.168.42.1"
                help
                    Default gateway (e.g., 192.168.42.1)
        endif
    endif

endmenu

menu "ETH Configuration"
    config EXAMPLE_ETH_DEINIT_AFTER_S
        int "Stop and deinit Ethernet after elapsing number of secs"
        range -1 300
        default -1
        help
            This option is for demonstration purposes only to demonstrate deinitialization of the Ethernet driver.
            Set to -1 to not deinitialize.
endmenu

menu "MQTT Configuration"
    config BROKER_URL
        string "Broker URL"
        default "mqtt://192.168.42.15:51111"
        help
            URL of the mqtt broker to which the esp32 will connect
    
    config BROKER_URL_FROM_STDIN
        bool "Read Broker URL from stdin"
        default n
        help
            If this option is enabled, the broker URL can be input via stdin
endmenu

menu "Sound Configuration"

    choice EXAMPLE_MODE
        prompt "Example mode"
        default EXAMPLE_MODE_MUSIC
        help
            Select example work mode

        config EXAMPLE_MODE_MUSIC
            bool "music"
    endchoice

    choice EXAMPLE_SELECT_MIC_GAIN
        prompt "Set MIC gain"
        depends on EXAMPLE_MODE_ECHO
        default MIC_GAIN_18DB
        help
            Select mic gain for echo mode

        config MIC_GAIN_0DB
            bool "0dB"
        config MIC_GAIN_6DB
            bool "6dB"
        config MIC_GAIN_12DB
            bool "12dB"
        config MIC_GAIN_18DB
            bool "18dB"
        config MIC_GAIN_24DB
            bool "24dB"
        config MIC_GAIN_30DB
            bool "30dB"
        config MIC_GAIN_36DB
            bool "36dB"
        config MIC_GAIN_42DB
            bool "42dB"
    endchoice

    config EXAMPLE_MIC_GAIN
        int
        default 0 if MIC_GAIN_0DB
        default 1 if MIC_GAIN_6DB
        default 2 if MIC_GAIN_12DB
        default 3 if MIC_GAIN_18DB
        default 4 if MIC_GAIN_24DB
        default 5 if MIC_GAIN_30DB
        default 6 if MIC_GAIN_36DB
        default 7 if MIC_GAIN_42DB

    config EXAMPLE_VOICE_VOLUME
        int "Voice volume"
        range 0 100
        default 60
        help
            Set voice volume

    config EXAMPLE_BSP
        bool "Enable Board Support Package (BSP) support"
        default n
        help
            Use BSP to setup all hardware settings. Specific board must be selected in main/idf_component.yml file.
endmenu
