menu "Luloc-ASTI: 0. Main Configuration"

config ROBOT_USE_ETHERNET
    bool "Enable Ethernet"
    default y

    if ROBOT_USE_ETHERNET
        choice ROBOT_ETH_IP_MODE
            prompt "Ethernet IP Configuration"
            default ROBOT_ETH_DHCP
            help
                Select whether to use DHCP or static IP address

            config ROBOT_ETH_DHCP
                bool "DHCP (automatic IP)"
                help
                    Use DHCP to automatically obtain IP address

            config ROBOT_ETH_STATIC_IP
                bool "Static IP address"
                help
                    Use fixed static IP address
        endchoice

        if ROBOT_ETH_STATIC_IP
            config ROBOT_ETH_STATIC_IP_ADDR
                string "Static IP address"
                default "192.168.42.151"
                help
                    Static IP address (e.g., 192.168.42.151)

            config ROBOT_ETH_STATIC_NETMASK
                string "Netmask"
                default "255.255.255.0"
                help
                    Netmask (e.g., 255.255.255.0)

            config ROBOT_ETH_STATIC_GATEWAY
                string "Gateway"
                default "192.168.42.1"
                help
                    Default gateway (e.g., 192.168.42.1)
        endif
    endif

    config ROBOT_CONTROL_PERIOD_MS
        int "Main Control Loop Period (ms)"
        default 10
        range 1 100
        help
            Period in milliseconds for the main RTOS motor control and PID loop.
            10 ms = 100 Hz, 2 ms = 500 Hz.

    config TELEMETRY_INTERVAL_CALIBRATION_MS
        int "Telemetry: Motor Calibration Interval (ms)"
        default 50
        help
            Publish interval for motor PID calibration metrics (e.g., 20ms = 50Hz)

    config TELEMETRY_INTERVAL_ODOMETRY_MS
        int "Telemetry: Odometry Publish Interval (ms)"
        default 1000
        help
            Frequency to push odometry (X, Y, Theta) data.

    config TELEMETRY_INTERVAL_SYSTEM_MS
        int "Telemetry: System Status Publish Interval (ms)"
        default 5000
        help
            Frequency to push CPU Load and general system heartbeat.

    config TELEMETRY_INTERVAL_FOLLOW_LINE_MS
        int "Telemetry: Follow Line Publish Interval (ms)"
        default 50
        help
            Publish interval for line follower PID and sensor metrics (e.g., 50ms = 20Hz)

endmenu

menu "Luloc-ASTI: 1. Follow Line Configuration"

    config FOLLOW_LINE_KP
        string "Line Follower: Kp (Proportional)"
        default "1.0"
        help
            Proportional gain for the line follower steering PID.

    config FOLLOW_LINE_KI
        string "Line Follower: Ki (Integral)"
        default "0.0"
        help
            Integral gain for the line follower steering PID.

    config FOLLOW_LINE_KD
        string "Line Follower: Kd (Derivative)"
        default "0.1"
        help
            Derivative gain for the line follower steering PID.

    config FOLLOW_LINE_BASE_SPEED
        string "Line Follower: Base Speed (m/s)"
        default "0.2"
        help
            Default straight-line speed for the robot.

    config FOLLOW_LINE_MAX_SPEED
        string "Line Follower: Max Speed (m/s)"
        default "0.8"
        help
            Absolute maximum speed for any motor during steering.

    config FOLLOW_LINE_FF_WEIGHT
        string "Line Follower: FF Weight (0.0 to 1.0)"
        default "0.5"
        help
            Weighting factor for the curvature feed-forward multiplier. 
            0.0 = Ignore FF, 1.0 = Full application of FF.

endmenu

menu "Luloc-ASTI: 1.1. Follow Line Sensor Mapping"

    config LINE_ARRAY_SENSOR_COUNT
        int "Line sensor count"
        default 4
        range 1 8
        help
            Number of active line sensors in the array.

    config LINE_ARRAY_SENSOR_PITCH_MM
        int "Line sensor pitch (mm)"
        default 10
        range 1 50
        help
            Physical spacing between adjacent line sensors, in millimeters.

    config LINE_ARRAY_SENSOR_GPIO0
        int "Line sensor 0 GPIO"
        default 18
        range 0 54

    config LINE_ARRAY_SENSOR_GPIO1
        int "Line sensor 1 GPIO"
        default 17
        range 0 54

    config LINE_ARRAY_SENSOR_GPIO2
        int "Line sensor 2 GPIO"
        default 16
        range 0 54

    config LINE_ARRAY_SENSOR_GPIO3
        int "Line sensor 3 GPIO"
        default 19
        range 0 54

endmenu
