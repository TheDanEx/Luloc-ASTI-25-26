menu "Luloc-ASTI: 3. Control & Motors - Line Follower"

    config LINE_FOLLOWER_DEFAULT_KP
        string "Default Proportional Gain (Kp)"
        default "1.5"

    config LINE_FOLLOWER_DEFAULT_KI
        string "Default Integral Gain (Ki)"
        default "0.0"

    config LINE_FOLLOWER_DEFAULT_KD
        string "Default Derivative Gain (Kd)"
        default "0.5"

    config LINE_FOLLOWER_DEFAULT_BASE_SPEED
        string "Default Base Motor Speed"
        default "50.0"

    config LINE_FOLLOWER_DEFAULT_MAX_SPEED
        string "Default Max Motor Speed"
        default "100.0"

    config LINE_FOLLOWER_CAMERA_WEIGHT
        string "Default Camera Curvature Multiplier"
        default "20.0"
        help
            A multiplier applied directly to the camera curvature reading 
            (-1.0 to 1.0) which is then added as feed-forward steering.

endmenu
