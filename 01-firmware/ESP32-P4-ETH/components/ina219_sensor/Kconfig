menu "[UJI] 2. Sensors: INA219 Power Monitor"

    config INA219_I2C_PORT
        int "I2C Port Number"
        default 0
        help
            The I2C port used to communicate with the INA219.

    config INA219_I2C_SDA_PIN
        int "I2C SDA Pin"
        default 21
        help
            The GPIO mapped to the I2C Data line. 
            Default 21 for older ESP32s, ESP32-P4 might map differently.

    config INA219_I2C_SCL_PIN
        int "I2C SCL Pin"
        default 22
        help
            The GPIO mapped to the I2C Clock line.

    config INA219_I2C_CLOCK_SPEED_HZ
        int "I2C Clock Speed (Hz)"
        default 400000
        help
            I2C Bus speed. Default is 400kHz.

    config INA219_SHUNT_OHMS
        string "Shunt Resistor Value (Ohms)"
        default "0.01"
        help
            Value of the shunt resistor mounted on the INA219 board.
            Usually 0.1 ohm or 0.01 ohm for high current.

    config INA219_MAX_EXPECTED_AMPS
        string "Maximum Expected Amps (A)"
        default "3.2"
        help
            Used to calculate the internal LSB scaling for the INA219.

    config INA219_POLLING_RATE_HZ
        int "Polling Rate in LP Task (Hz)"
        default 5
        help
            How many times per second the low-power CPU reads the sensor
            and updates shared memory.

    config INA219_TELEMETRY_RATE_MS
        int "MQTT Telemetry Rate (ms)"
        default 1000
        help
            How often the batched data is physically transmitted over MQTT.

    config INA219_MQTT_TOPIC
        string "MQTT Telemetry Topic"
        default "robot/telemetry/power"
        help
            Topic name for the InfluxDB Line Protocol power payloads.

endmenu
